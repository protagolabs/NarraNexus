# =============================================================================
# NarraNexus Cloud Deployment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.cloud.example .env
#
# Then run:
#   bash scripts/deploy-cloud.sh
# =============================================================================

# --- Database (MySQL) ---
# AWS RDS or local MySQL instance
DATABASE_URL=mysql://narranexus:YOUR_PASSWORD@YOUR_RDS_HOST:3306/narranexus

# --- Authentication ---
# Random secret for JWT signing (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# --- Invite codes ---
# Registration is gated by per-code invite codes (the old single global
# INVITE_CODE env var is gone). Codes are requested at narra.nexus/invite
# and managed via /api/admin/invite. This cap is the lever that limits
# web-version user count: while issued+used codes < cap, requests are
# auto-issued; past it, new requests are waitlisted.
INVITE_AUTO_ISSUE_CAP=200

# Shared secret for the server-to-server POST /api/invite/internal/issue
# endpoint, called by the narranexus-website backend. Generate with:
#   openssl rand -hex 32
# Set the SAME value on the website deployment (env var of the same name).
# Without this set, /api/invite/internal/issue returns 503 — invite
# issuance is effectively disabled.
INTERNAL_INVITE_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# SMTP (for sending the invite-code emails) lives in the narranexus-website
# deployment now — NarraNexus no longer holds those credentials.

# --- LLM API Keys (optional — users can configure their own) ---
# Staff users can use server-configured keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Paths ---
# Where agent workspaces are stored on disk
BASE_WORKING_PATH=/opt/narranexus/workspaces
