# =============================================================================
# NarraNexus Cloud Deployment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.cloud.example .env
#
# Then run:
#   bash scripts/deploy-cloud.sh
# =============================================================================

# --- Database (MySQL) ---
# AWS RDS or local MySQL instance
DATABASE_URL=mysql://narranexus:YOUR_PASSWORD@YOUR_RDS_HOST:3306/narranexus

# --- Authentication ---
# Random secret for JWT signing (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# --- Invite codes ---
# Registration is gated by per-code invite codes (the old single global
# INVITE_CODE env var is gone). Codes are requested at narra.nexus/invite
# and managed via /api/admin/invite. This cap is the lever that limits
# web-version user count: while issued+used codes < cap, requests are
# auto-issued; past it, new requests are waitlisted.
INVITE_AUTO_ISSUE_CAP=200

# Shared secret for the server-to-server POST /api/invite/internal/issue
# endpoint, called by the narranexus-website backend. Generate with:
#   openssl rand -hex 32
# Set the SAME value on the website deployment (env var of the same name).
# Without this set, /api/invite/internal/issue returns 503 — invite
# issuance is effectively disabled.
INTERNAL_INVITE_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# SMTP (for sending the invite-code emails) lives in the narranexus-website
# deployment now — NarraNexus no longer holds those credentials.

# --- LLM API Keys (optional — users can configure their own) ---
# Staff users can use server-configured keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- LLM runtime resilience (#7; all optional, sane defaults shown) ---
# Per-REQUEST timeout for the Claude Code CLI's LLM calls (NOT a run total —
# the agent loop has no force-stop). A stalled/dead request errors after this
# and the CLI auto-retries. 10 min is generous enough not to cut a legitimately
# streaming long-thinking pass.
LLM_API_TIMEOUT_MS=600000
# CLI built-in retry count for transient errors (429 / 5xx / connection),
# same provider, count-bounded.
LLM_MAX_RETRIES=10
# When a run emits NO events for this long (true silence, subprocess alive), the
# server probes the provider endpoint and logs reachable-vs-dead (diagnostic
# only; never force-stops the run).
LLM_STALL_PROBE_AFTER_SECONDS=600
LLM_STALL_PROBE_TIMEOUT_SECONDS=10

# --- NetMind environment (billing / subscription / key-mint / inference) ---
# ALL of these must point at the SAME NetMind environment as the login domain
# the frontend uses (config.js netmindAuthApi). Defaults are PROD; a dev/staging
# deployment MUST override every line to the dev hosts, or a dev-issued token /
# dev-minted key will be rejected by prod (401/403).
#   prod (leave unset / default)          |  dev (protago-dev)
#   auth   auth-api.netmind.ai            |  userauth.protago-dev.com
#   billing billing.api.netmind.ai        |  billing.api.protago-dev.com
#   key    platform-api.netmind.ai        |  mind-web.protago-dev.com
#   infer  api.netmind.ai/inference-api   |  test.api.netmind.ai/inference-api
NETMIND_AUTH_API_URL=
BILLING_API_BASE=
NETMIND_KEY_API_BASE=
# Inference base is used ONLY by the "use my subscription" minted-key path
# (manual paste always uses prod). Set it to the SAME env as the key host above.
NETMIND_INFERENCE_BASE=
# Module F gate: keep FALSE until the minted-key billing contract (C1) is
# verified end-to-end on the target environment.
NETMIND_USE_SUBSCRIPTION_ENABLED=false

# --- Paths ---
# Where agent workspaces are stored on disk
BASE_WORKING_PATH=/opt/narranexus/workspaces

# -----------------------------------------------------------------------------
# Product feedback telemetry
# -----------------------------------------------------------------------------
# The agent's submit_feedback tool and the Web UI feedback dialog report
# problems to the NarraNexus team's central intake. What leaves the machine:
# a one-line problem SUMMARY written by the agent/user, a category/severity,
# and sha256-HASHED agent/user ids — never conversation text, never raw ids.
# Set to 1 to disable all outbound feedback (self-hosted opt-out):
# NARRANEXUS_FEEDBACK_DISABLED=1
# Point at a different intake (dev/test environments):
# NARRANEXUS_FEEDBACK_URL=

# ============================================================================
# Skill / Team Marketplace — S3 artifact storage + secrets
# ============================================================================
# S3 bucket for marketplace artifacts (skill .zip, team .nxbundle). Unset =
# fall back to a LOCAL store under ~/.nexusagent/marketplace_store (single
# host only). boto3 uses the EC2 instance role automatically — no AWS keys
# needed when the instance has a role attached (recommended).
# SKILL_S3_BUCKET=nexus-marketplace-891377017161
# SKILL_S3_REGION=eu-west-2
# One knob for the dev/prod x skills/teams layout: keys land under
# <env>/skills/... and <env>/teams/... in the shared bucket.
# MARKETPLACE_S3_ENV=prod
#
# Fernet key for encrypting skill env_config (credentials) at rest.
# REQUIRED on any MULTI-POD cloud deploy: without it each pod generates its
# own local key file, so a credential encrypted on pod A cannot be decrypted
# on pod B (skills silently run without their key). Single-pod deploys fall
# back to a file key and work, but SET THIS for any horizontally-scaled tier.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SKILL_SECRETS_KEY=CHANGE_ME_TO_A_FERNET_KEY
#
# Token that gates POST /api/marketplace/skills/publish (ops/CI publishers).
# Unset on cloud = publishing is closed (403); set to enable CLI publishing.
# MARKETPLACE_PUBLISH_TOKEN=CHANGE_ME_TO_A_RANDOM_STRING
