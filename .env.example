# =============================================================================
# LLM API Keys
# =============================================================================
OPENAI_API_KEY=""
GOOGLE_API_KEY=""

# Anthropic（可选）：填写 API Key 则走 API Key 模式，留空/删除则走 Claude Code OAuth 登录
# ANTHROPIC_API_KEY=""
# ANTHROPIC_BASE_URL=""

# =============================================================================
# Database (MySQL)
# =============================================================================
# 方式一：使用 DATABASE_URL
# DATABASE_URL="mysql://root:xyz_root_pass@127.0.0.1:3306/xyz_agent_context"

# 方式二：使用独立变量（推荐，run.sh install 会自动填充 Docker MySQL 默认值）
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_NAME="xyz_agent_context"
DB_USER="root"
DB_PASSWORD="xyz_root_pass"

# =============================================================================
# Auth
# =============================================================================
ADMIN_SECRET_KEY=""

# =============================================================================
# Workspace（可选，有默认值）
# =============================================================================
# BASE_WORKING_PATH="./agent_workspace"

# =============================================================================
# External API protocol (v0.3) — agent-bound nxk_ tokens
# =============================================================================
# Set to 1 to expose /v1/external/* endpoints for integrators calling
# NarraNexus via OpenAI-compatible HTTP. Owners mint per-agent API keys
# from the agent detail page; integrators pass the key as
# `Authorization: Bearer nxk_apk_...`. Default off — vanilla cloud /
# `bash run.sh` / Tauri DMG keep the /api/* surface only.
# See docs/external-api.md for the contract.
# ENABLE_EXTERNAL_API=1
